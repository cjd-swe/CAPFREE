# Telegram bot token from @BotFather. Leave empty to skip polling on startup.
TELEGRAM_BOT_TOKEN=

# Comma-separated allowed CORS origins. Add your deployed frontend URL here.
# Example (prod): http://localhost:3000,https://sharpwatch.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Database URL (REQUIRED). No local fallback — every environment uses Postgres.
#
# Two Supabase projects: sharpwatch-dev and sharpwatch-prod.
# Project Settings → Database → Connection string → URI
#
# Dev (transaction pooler — for local dev):
#   DATABASE_URL=postgresql://postgres.jpxkywxrcuxvfwgyygxs:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres
#
# Prod (transaction pooler — for Render web server):
#   DATABASE_URL=postgresql://postgres.oznsiignyfapeppkfjyq:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres
#
# The `postgresql+asyncpg://` driver prefix is added automatically by
# app/database.py — paste the provider URL verbatim.
DATABASE_URL=
